  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "tailwindcss": "^4.3.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "pnpm@11.5.0"
}
